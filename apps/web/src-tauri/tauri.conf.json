{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Profile Fill Assistant",
  "version": "0.1.0",
  "identifier": "app.profile-fill-assistant",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Profile Fill Assistant",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
