{
  "name": "profile-fill-assistant",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev:web",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build:web",
    "check-types": "turbo check-types",
    "serve:web": "pnpm --filter web serve"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.29.2"
}
